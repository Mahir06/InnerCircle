rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember(circleId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds;
    }

    // A user owns exactly their own doc. Any signed-in user can read
    // profiles (needed to render member names before/while joining).
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Global daily prompts pool: readable by everyone signed in,
    // written only by Cloud Functions (admin SDK bypasses rules).
    match /sparks/{sparkId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Game Shelf content decks, seeded server-side.
    match /gameContent/{deckId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /circles/{circleId} {
      // Read requires sign-in. Group Ticket lookups are a single
      // indexed query on `code`; membership gates everything inside.
      allow read: if signedIn();

      // Creator must put exactly themselves in memberIds.
      allow create: if signedIn()
        && request.resource.data.memberIds == [request.auth.uid]
        && request.resource.data.code is string
        && request.resource.data.code.size() == 6;

      // Members can edit the circle. Non-members can update only to
      // join: append exactly their own uid to memberIds, max 10 seats.
      allow update: if signedIn() && (
        request.auth.uid in resource.data.memberIds
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds)
          && request.resource.data.memberIds.size() <= 10
        )
      );

      allow delete: if false;

      // Everything inside a circle (messages, hangouts, postcards,
      // stamps, games, whispers) is members-only.
      match /{document=**} {
        allow read, write: if isMember(circleId);
      }
    }
  }
}
