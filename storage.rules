rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Circle media (postcard photos, posters, banners): members only.
    match /circles/{circleId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
    }

    // Avatars: anyone signed in can see, only you can change yours.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
